import pytz
import pycountry
import json

def generate_full_json():
    full_data = []
    # Loop through every country recognized globally
    for country in pycountry.countries:
        try:
            # 1. Get all Timezones for this country code (e.g., 'US')
            zones = pytz.country_timezones.get(country.alpha_2, [])
            
            # 2. Get Currency details
            currency = pycountry.currencies.get(numeric=country.numeric)
            
            # 3. Only add to our list if we have timezone data
            if zones:
                full_data.append({
                    "code": country.alpha_2,     # e.g., "GH"
                    "name": country.name,       # e.g., "Ghana"
                    "currency": currency.alpha_3 if currency else "N/A",
                    "zones": zones              # e.g., ["Africa/Accra"]
                })
        except Exception:
            continue # Skip any territories with missing data
    
    # Save this to a file
    with open('data.json', 'w') as f:
        json.dump(full_data, f, indent=4)
    print("Successfully created data.json with all countries!")

generate_full_json()
